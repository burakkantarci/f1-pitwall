# PostgreSQL
POSTGRES_DB=pitwall
POSTGRES_USER=pitwall
POSTGRES_PASSWORD=pitwall_dev

# API Service
API_PORT=3001
DATABASE_URL=postgresql://pitwall:pitwall_dev@postgres:5432/pitwall
REDIS_URL=redis://redis:6379

# Ingestion Service
OPENF1_BASE_URL=https://api.openf1.org/v1
ERGAST_BASE_URL=https://api.jolpi.ca/ergast/f1

# Frontend
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Observability backends (uncomment as needed)
# DD_API_KEY=your-datadog-api-key
# ELASTIC_APM_ENDPOINT=your-elastic-endpoint
# ELASTIC_APM_TOKEN=your-elastic-token
# GRAFANA_OTLP_ENDPOINT=your-grafana-endpoint
# GRAFANA_OTLP_TOKEN=your-grafana-token
